<Window x:Class="MiniCompilerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CompileX Studio" Height="900" Width="1400">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,0,0,1" Padding="12" Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x26A1;" FontSize="20" Foreground="{StaticResource AccentPrimary}"/>
                    <TextBlock Text="CompileX Studio" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource AccentPrimary}" Margin="8,0,0,0"/>
                </StackPanel>
                <ItemsControl Grid.Column="1" ItemsSource="{Binding PhaseStatuses}" AlternationCount="6">
                    <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="72" Height="22" CornerRadius="10" Background="{StaticResource SurfaceBg}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1" Margin="0,0,8,0">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource PhaseNameConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding}" Value="Success">
                                                    <Setter Property="Foreground" Value="#0D1117"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding}" Value="Error">
                                                    <Setter Property="Foreground" Value="#0D1117"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="Success">
                                                <Setter Property="Background" Value="{StaticResource AccentSuccess}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentSuccess}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="Error">
                                                <Setter Property="Background" Value="{StaticResource AccentError}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentError}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="42*"/>
                <ColumnDefinition Width="58*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource AppBg}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1,1,0,1">
                        <ItemsControl ItemsSource="{Binding LineNumbers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextSecondary}" FontSize="13" HorizontalAlignment="Right" Margin="0,0,6,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <TextBox x:Name="SourceCodeBox" Grid.Column="1" Text="{Binding SourceCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBoxStyle}" SelectionChanged="SourceCodeBox_SelectionChanged"/>
                </Grid>

                <Border Grid.Row="1" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1,0,1,1" Padding="8">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="&#x25B6; Run" Style="{StaticResource PrimaryButtonStyle}" Click="RunAll_Click" Margin="0,0,8,0"/>
                        <Button Content="&#x2715; Clear" Click="Clear_Click" Margin="0,0,8,0"/>
                        <Button Content="&#x21E3; Load File" Click="LoadFile_Click" Margin="0,0,8,0"/>
                        <Button Content="&#x21E1; Export IR" Click="ExportIr_Click" Margin="0,0,8,0"/>
                        <ComboBox x:Name="TestCaseCombo" Width="220" ItemsSource="{Binding Cases}" DisplayMemberPath="Name" SelectionChanged="TestCaseCombo_SelectionChanged"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1" Padding="4">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="# Tokens" Style="{StaticResource TabRadioButtonStyle}" IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IndexToBooleanConverter}, ConverterParameter=0}" Margin="0,0,8,0"/>
                        <RadioButton Content="{} Syntax" Style="{StaticResource TabRadioButtonStyle}" IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IndexToBooleanConverter}, ConverterParameter=1}" Margin="0,0,8,0"/>
                        <RadioButton Content="$ Symbols" Style="{StaticResource TabRadioButtonStyle}" IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IndexToBooleanConverter}, ConverterParameter=2}" Margin="0,0,8,0"/>
                        <RadioButton Content="~ IR Code" Style="{StaticResource TabRadioButtonStyle}" IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IndexToBooleanConverter}, ConverterParameter=3}" Margin="0,0,8,0"/>
                        <RadioButton Content="&#x26A1; Opt IR" Style="{StaticResource TabRadioButtonStyle}" IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IndexToBooleanConverter}, ConverterParameter=4}" Margin="0,0,8,0"/>
                        <RadioButton Content="&#x229E; Target" Style="{StaticResource TabRadioButtonStyle}" IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IndexToBooleanConverter}, ConverterParameter=5}" Margin="0,0,8,0"/>
                        <Grid>
                            <RadioButton Content="&#x26A0; Errors" Style="{StaticResource TabRadioButtonStyle}" IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IndexToBooleanConverter}, ConverterParameter=6}"/>
                            <Border Background="{StaticResource AccentError}" Width="18" Height="18" CornerRadius="9" HorizontalAlignment="Right" Margin="4,0,0,0"
                                    Visibility="{Binding ErrorCount, Converter={StaticResource ZeroToVisibilityConverter}, ConverterParameter=Invert}">
                                <TextBlock Text="{Binding ErrorCount}" Foreground="White" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <ContentControl Grid.Row="1" Margin="0,8,0,0">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="ContentTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <TextBox Style="{StaticResource OutputTextBoxStyle}" Text="{Binding SyntaxTree}"/>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <DataGrid ItemsSource="{Binding Tokens}">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Type" Binding="{Binding Type}"/>
                                                        <DataGridTextColumn Header="Value" Binding="{Binding Value}"/>
                                                        <DataGridTextColumn Header="Line" Binding="{Binding Line}"/>
                                                        <DataGridTextColumn Header="Column" Binding="{Binding Column}"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource OutputTextBoxStyle}" Text="{Binding SyntaxTree}"/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <DataGrid ItemsSource="{Binding Symbols}">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>
                                                        <DataGridTextColumn Header="Type" Binding="{Binding Type}"/>
                                                        <DataGridTextColumn Header="Scope" Binding="{Binding Scope}"/>
                                                        <DataGridTextColumn Header="Value" Binding="{Binding Value}"/>
                                                        <DataGridTextColumn Header="IsUsed" Binding="{Binding IsUsed}"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource OutputTextBoxStyle}" Text="{Binding IRText}"/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="4">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource OutputTextBoxStyle}" Text="{Binding OptimizedIRText}"/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="5">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource OutputTextBoxStyle}" Text="{Binding TargetCodeText}"/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="6">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <Border Background="{StaticResource AccentSuccess}" CornerRadius="6" Padding="10" Margin="0,0,0,8"
                                                            Visibility="{Binding ErrorCount, Converter={StaticResource ZeroToVisibilityConverter}}">
                                                        <TextBlock Foreground="White">
                                                            <Run Text="&#x2713; Compilation successful - 0 errors, "/>
                                                            <Run Text="{Binding WarningCount}"/>
                                                            <Run Text=" warnings"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <DataGrid Grid.Row="1" ItemsSource="{Binding Errors}">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Phase" Binding="{Binding Phase}"/>
                                                            <DataGridTemplateColumn Header="Severity">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Style="{StaticResource SeverityIconStyle}"/>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTextColumn Header="Code" Binding="{Binding Code}"/>
                                                            <DataGridTextColumn Header="Line" Binding="{Binding Line}"/>
                                                            <DataGridTextColumn Header="Col" Binding="{Binding Column}"/>
                                                            <DataGridTextColumn Header="Message" Binding="{Binding Message}">
                                                                <DataGridTextColumn.ElementStyle>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="ToolTipService.ToolTip" Value="{Binding SourceSnippet}"/>
                                                                    </Style>
                                                                </DataGridTextColumn.ElementStyle>
                                                            </DataGridTextColumn>
                                                            <DataGridTextColumn Header="Suggestion" Binding="{Binding Suggestion}"/>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </Grid>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource AppBg}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1,1,1,0" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ItemsControl ItemsSource="{Binding PhaseStatuses}" Grid.Column="0" AlternationCount="6">
                    <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Ellipse Width="8" Height="8" Fill="{StaticResource TextSecondary}" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="Success">
                                                <Setter Property="Fill" Value="{StaticResource AccentSuccess}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="Error">
                                                <Setter Property="Fill" Value="{StaticResource AccentError}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Grid.Column="1" Foreground="{StaticResource TextSecondary}">
                    <Run Text="Ln "/>
                    <Run Text="{Binding CurrentLine}"/>
                    <Run Text=" Col "/>
                    <Run Text="{Binding CurrentColumn}"/>
                    <Run Text="  |  "/>
                    <Run Text="{Binding TokenCount}"/>
                    <Run Text=" tokens"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
